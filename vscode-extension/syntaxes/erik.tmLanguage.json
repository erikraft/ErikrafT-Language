{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "ErikrafT",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#constants" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#functions" },
        { "include": "#ai-primitives" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.erik",
                    "match": "//.*"
                },
                {
                    "name": "comment.block.erik",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.erik",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        { "name": "constant.character.escape.erik", "match": "\\\\." },
                        { "name": "variable.interpolation.erik", "match": "\\{[^}]*\\}" }
                    ]
                },
                {
                    "name": "string.quoted.single.erik",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        { "name": "constant.character.escape.erik", "match": "\\\\." }
                    ]
                },
                {
                    "name": "string.quoted.backtick.erik",
                    "begin": "`",
                    "end": "`"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.erik",
                    "match": "\\b(if|else|match|for|while|break|continue|return|try|catch|throw|async|await|spawn|use|pub|let|const|type)\\b"
                },
                {
                    "name": "keyword.declaration.erik",
                    "match": "\\b(fn|struct|class|interface|trait|enum|component|render|impl|for)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.primitive.erik",
                    "match": "\\b(int|float|string|bool|char|byte|nil|self|Self)\\b"
                },
                {
                    "name": "entity.name.type.erik",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.erik",
                    "match": "\\b(true|false|nil)\\b"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.erik",
                    "match": "\\b\\d+\\.\\d+\\b"
                },
                {
                    "name": "constant.numeric.integer.erik",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arithmetic.erik",
                    "match": "\\+|-|\\*|/|%|\\*\\*"
                },
                {
                    "name": "keyword.operator.logical.erik",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.comparison.erik",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.assignment.erik",
                    "match": "=|\\+=|-=|\\*=|/="
                },
                {
                    "name": "keyword.operator.misc.erik",
                    "match": "\\.\\.|\\.\\.=|\\|>|\\?\\.|\\?\\?|->|=>"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.erik",
                    "match": "\\b([a-z][a-zA-Z0-9_]*)(?=\\s*\\()"
                }
            ]
        },
        "ai-primitives": {
            "patterns": [
                {
                    "name": "support.function.ai.erik",
                    "match": "\\bai\\.(chat|image|agent|ask)\\b"
                }
            ]
        }
    },
    "scopeName": "source.erik"
}
